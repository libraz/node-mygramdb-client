{
  "name": "mygramdb-client",
  "version": "1.1.0",
  "description": "Node.js client library for MygramDB - High-performance in-memory full-text search engine",
  "type": "module",
  "packageManager": "yarn@4.9.1",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "lib",
    "binding.gyp",
    "native"
  ],
  "binary": {
    "module_name": "mygram_native",
    "module_path": "./lib/binding/{node_abi}-{platform}-{arch}",
    "host": "https://github.com/libraz/node-mygramdb-client/releases/download/",
    "remote_path": "{version}",
    "package_name": "{module_name}-v{version}-{node_abi}-{platform}-{arch}.tar.gz"
  },
  "scripts": {
    "dev": "vite",
    "build": "yarn clean && yarn build:ts && yarn build:native && node scripts/postbuild-copy.cjs",
    "build:ts": "tsc && vite build",
    "build:native": "node-gyp rebuild",
    "build:native:debug": "node-gyp rebuild --debug",
    "clean": "rimraf dist lib build",
    "clean:native": "rimraf build lib",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "vitest run tests/e2e.test.ts --config vitest.e2e.config.ts",
    "test:all": "vitest run --config vitest.e2e.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "install": "node-pre-gyp install --fallback-to-build || node-gyp rebuild || echo 'Native build optional, using pure JavaScript fallback'",
    "prepare": "yarn build || echo 'Build failed, but package still usable with pure JS'",
    "prepublishOnly": "yarn clean && yarn lint && yarn test run && yarn build",
    "postinstall": "simple-git-hooks || true"
  },
  "keywords": [
    "mygramdb",
    "fulltext",
    "search",
    "mysql",
    "client",
    "database",
    "ngram",
    "typescript"
  ],
  "author": "libraz <libraz@libraz.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libraz/node-mygramdb-client.git"
  },
  "bugs": {
    "url": "https://github.com/libraz/node-mygramdb-client/issues"
  },
  "homepage": "https://github.com/libraz/node-mygramdb-client#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bindings": "^1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "node-gyp": "^12.2.0",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "5.5.4",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "22.22.1",
    "yarn": "4.12.0"
  },
  "dependencies": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "bindings": "^1.5.0"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn lint"
  }
}
