{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "files": {
    "includes": ["src/**", "tests/**"]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "none",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "style": {
        "noDefaultExport": "error",
        "useConst": "error",
        "useTemplate": "error",
        "noNonNullAssertion": "warn",
        "useExponentiationOperator": "error",
        "useEnumInitializers": "off",
        "noParameterAssign": "error"
      },
      "suspicious": {
        "noConsole": "warn",
        "noExplicitAny": "warn",
        "noAssignInExpressions": "error",
        "noDoubleEquals": "error",
        "noRedeclare": "error",
        "noShadowRestrictedNames": "error"
      },
      "complexity": {
        "noForEach": "off",
        "useFlatMap": "error",
        "noStaticOnlyClass": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["tests/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
